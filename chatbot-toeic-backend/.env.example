# ========== SERVER CONFIG ==========
NODE_ENV=development
PORT=8080
HOSTNAME=localhost
API_URL=http://localhost:8080

# ========== CORS CONFIG (comma-separated origins) ==========
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ========== ML CONFIG ==========
# ML retrain logging (default quiet). Set to true to show cron + Python train logs.
ML_RETRAIN_VERBOSE=false

# Auto-run ML prediction after submit test/practice. Set false to disable.
ML_AUTO_PREDICTION=true

# ========== DATABASE CONFIG ==========
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASS=your-password-here
DB_NAME=ChatbotToeic
DB_ENCRYPT=false
SA_PASSWORD=your-password-here

# ========== JWT CONFIG ==========
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ========== GEMINI AI CONFIG ==========
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
GEMINI_API_KEYS=your-gemini-api-keys-here

# ========== GOOGLE CONFIG ==========
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ========== EMAIL CONFIG (Nodemailer) ==========
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password

# ========== CLOUDINARY CONFIG ==========
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========== REDIS CONFIG (Optional, for caching) ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== ML MODEL CONFIG ==========
ML_MODEL_PATH=./ml/model
ML_RETRAIN_INTERVAL=21600000
